#!/bin/bash
# Maya AI Assistant - macOS App Launcher

# Get the app's contents directory
APP_DIR="$( cd "$( dirname "${BASH_SOURCE[0]}" )" && cd ../.. && pwd )"

# Get the project root (parent of the app)
PROJECT_DIR="$( cd "$APP_DIR" && pwd )"

# Change to project directory
cd "$PROJECT_DIR"

# Source the launch script
"$PROJECT_DIR/launch_maya.sh"
